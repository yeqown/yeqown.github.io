    <item>
      <title>docker&#43;selenium&#43;pythonжһ„е»әеүҚз«ҜиҮӘеҠЁеҢ–еҲҶеёғејҸжөӢиҜ•зҺҜеўғ</title>
      <link>https://www.yeqown.xyz/2018/01/23/docker-selenium-python%E6%9E%84%E5%BB%BA%E5%89%8D%E7%AB%AF%E8%87%AA%E5%8A%A8%E5%8C%96%E5%88%86%E5%B8%83%E5%BC%8F%E6%B5%8B%E8%AF%95%E7%8E%AF%E5%A2%83/</link>
      <pubDate>Tue, 23 Jan 2018 11:07:08 +0000</pubDate>
      <guid>https://www.yeqown.xyz/2018/01/23/docker-selenium-python%E6%9E%84%E5%BB%BA%E5%89%8D%E7%AB%AF%E8%87%AA%E5%8A%A8%E5%8C%96%E5%88%86%E5%B8%83%E5%BC%8F%E6%B5%8B%E8%AF%95%E7%8E%AF%E5%A2%83/</guid>
      <description>&lt;p&gt;docker + selenium + python жһ„е»әеүҚз«ҜиҮӘеҠЁеҢ–еҲҶеёғејҸжөӢиҜ•зҺҜеўғгҖӮеҲ©з”Ёseleninum-gridеҲҶеёғејҸжЎҶжһ¶пјҢpythonзј–еҶҷжөӢиҜ•д»Јз ҒпјҢdockerйғЁзҪІжқҘиҝӣиЎҢеүҚз«ҜиҮӘеҠЁеҢ–жөӢиҜ•&lt;/p&gt;&#xA;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xA;&lt;p&gt;2018-2-1 жӣҙж–° &lt;a href=&#34;#%e4%bd%bf%e7%94%a8docker-compose%e7%bc%96%e6%8e%92&#34;&gt;дҪҝз”Ёdocker-composeзј–жҺ’&lt;/a&gt;&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;!-- more --&gt;&#xA;&lt;h3 id=&#34;еҲҶеёғејҸйғЁзҪІзҡ„дјҳзӮ№&#34;&gt;еҲҶеёғејҸйғЁзҪІзҡ„дјҳзӮ№&lt;a class=&#34;anchor&#34; href=&#34;#%e5%88%86%e5%b8%83%e5%bc%8f%e9%83%a8%e7%bd%b2%e7%9a%84%e4%bc%98%e7%82%b9&#34;&gt;#&lt;/a&gt;&lt;/h3&gt;&#xA;&lt;p&gt;иҮӘеҠЁеҢ–зҡ„дјҳзјәзӮ№е°ұдёҚеҶҚйҮҚеӨҚдәҶпјҢдё»иҰҒеҲҶжһҗдёӢdockeйғЁзҪІе’ҢеҲҶеёғејҸзҡ„дјҳеҠҝ&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;жҸҗй«ҳиҮӘеҠЁеҢ–зҡ„жөӢиҜ•ж•ҲзҺҮпјҲеҲҶеёғејҸпјү&lt;/li&gt;&#xA;&lt;li&gt;ж–№дҫҝжү“еҢ…е’ҢжҢҒз»ӯйӣҶжҲҗпјҲdockerпјү&lt;/li&gt;&#xA;&lt;li&gt;и§ЈеҶіеӨҡдәәcodingпјҢеҚҙеӣ дёәи·Ҝеҫ„дёҚдёҖиҮҙеҜјиҮҙж— жі•иҝҗиЎҢзҡ„й—®йўҳпјҲеҪ“з„¶д№ҹеҸҜд»ҘйҖҡиҝҮе…¶д»–ж–№ејҸжқҘи§ЈеҶіпҪһпјү&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;p&gt;иҝҷйҮҢиҝҳжңүдёҖдёӘй—®йўҳе°ұжҳҜпјҡдҪҝз”ЁdockerйғЁзҪІж–№ејҸиҝҗиЎҢжөӢиҜ•д»Јз ҒпјҢжҳҜзңӢдёҚи§Ғжң¬ең°жөҸи§ҲеҷЁеҗҜеҠЁзҡ„пјҢеӣ жӯӨеңЁи°ғиҜ•жөӢиҜ•д»Јз Ғзҡ„ж—¶еҖҷпјҢйңҖиҰҒдёҖе®ҡзҡ„е·Ҙе…·жқҘеҚҸеҠ©пјҢиӯ¬еҰӮ&lt;a href=&#34;https://www.realvnc.com/en/connect/download/viewer/&#34;&gt;VNC viewer&lt;/a&gt;&lt;/p&gt;&#xA;&lt;h3 id=&#34;ејҖзҜҮ-selenium&#34;&gt;ејҖзҜҮ-selenium&lt;a class=&#34;anchor&#34; href=&#34;#%e5%bc%80%e7%af%87-selenium&#34;&gt;#&lt;/a&gt;&lt;/h3&gt;&#xA;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xA;&lt;p&gt;еӨ§е®¶йғҪзҹҘйҒ“ Selenium жҳҜж”ҜжҢҒеӨҡз§ҚжөҸи§ҲеҷЁеӨҡдёӘзј–зЁӢиҜӯиЁҖзҡ„дёҖдёӘиҮӘеҠЁеҢ–жөӢиҜ•е·Ҙе…·гҖӮиҖҢ Selenium Grid жҳҜдёҖз§ҚеҸҜд»Ҙи®©з”ЁжҲ·еңЁдёҚеҗҢзҡ„зҺҜеўғе’ҢдёҚеҗҢзҡ„жөҸи§ҲеҷЁдёҠе№¶иЎҢиҝҗиЎҢ web жөӢиҜ•з”ЁдҫӢзҡ„жЎҶжһ¶гҖӮжҚўиҖҢиЁҖд№ӢпјҢдҪҝз”Ё Selenium Grid еҸҜд»Ҙи®©жҲ‘д»¬еңЁеҲҶеёғејҸжөӢиҜ•зҺҜеўғдёӢжү§иЎҢжөӢиҜ•пјҢдҫӢеҰӮ WindowsпјҢLinuxпјҢMac OSпјҢAndoid/iOS зӯүзӯүпјҢиҝҷж ·еҸҜд»ҘеӨ§еӨ§еҮҸе°‘йҮҚеӨҚзҡ„е·ҘдҪңйҮҸпјҢжҸҗй«ҳжҲ‘д»¬зҡ„е·ҘдҪңж•ҲзҺҮгҖӮ&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;p&gt;seleniumеҲҶеёғејҸз»“жһ„еҰӮеӣҫпјҡ&#xA;&lt;img src=&#34;https://www.ibm.com/developerworks/cn/opensource/os-cn-docker-selenium-grid-test/image001.png&#34; alt=&#34;selunium-grid&#34; /&gt;&lt;/p&gt;&#xA;&lt;h3 id=&#34;жҗӯе»әеҲҶеёғејҸзҺҜеўғ&#34;&gt;жҗӯе»әеҲҶеёғејҸзҺҜеўғ&lt;a class=&#34;anchor&#34; href=&#34;#%e6%90%ad%e5%bb%ba%e5%88%86%e5%b8%83%e5%bc%8f%e7%8e%af%e5%a2%83&#34;&gt;#&lt;/a&gt;&lt;/h3&gt;&#xA;&lt;p&gt;еңЁDockerhubе·Із»Ҹе…·жңүдәҶзӣёеә”зҡ„seleniumзҡ„й•ңеғҸпјҢжҲ‘д»¬зӣҙжҺҘдҪҝз”Ёе°ұиЎҢдәҶ&lt;/p&gt;&#xA;&lt;h4 id=&#34;жӢүеҸ–й•ңеғҸ&#34;&gt;жӢүеҸ–й•ңеғҸ&lt;a class=&#34;anchor&#34; href=&#34;#%e6%8b%89%e5%8f%96%e9%95%9c%e5%83%8f&#34;&gt;#&lt;/a&gt;&lt;/h4&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;docker pull selenium/hub&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;docker pull selenium/node-chorme-debug&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;е…ідәҺ&lt;code&gt;node-chrome-debug&lt;/code&gt;е’Ң&lt;code&gt;node-chrome&lt;/code&gt;зҡ„еҢәеҲ«пјҡ&#xA;жҡӮжңӘз ”з©¶&lt;/p&gt;&#xA;&lt;h4 id=&#34;иҝҗиЎҢе®№еҷЁ&#34;&gt;иҝҗиЎҢе®№еҷЁ&lt;a class=&#34;anchor&#34; href=&#34;#%e8%bf%90%e8%a1%8c%e5%ae%b9%e5%99%a8&#34;&gt;#&lt;/a&gt;&lt;/h4&gt;&#xA;&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;docker run -d -p 4444:4444 --name sel-hub selunium/hub # иҝҗиЎҢhubжңҚеҠЎ&#xA;docker run -d -p 5900:5900 --link sel-hub:hub selunium/node-chrome-debug # иҝҗиЎҢslenium chrome иҠӮзӮ№&#xA;# more node could append like node-chrome-debug&lt;/code&gt;&lt;/pre&gt;&lt;h4 id=&#34;жҹҘзңӢиҠӮзӮ№дҝЎжҒҜ&#34;&gt;жҹҘзңӢиҠӮзӮ№дҝЎжҒҜ&lt;a class=&#34;anchor&#34; href=&#34;#%e6%9f%a5%e7%9c%8b%e8%8a%82%e7%82%b9%e4%bf%a1%e6%81%af&#34;&gt;#&lt;/a&gt;&lt;/h4&gt;&#xA;&lt;p&gt;еңЁжөҸи§ҲеҷЁдёӯжү“ејҖ&lt;a href=&#34;http://127.0.0.1:4444/grid/console&#34;&gt;http://127.0.0.1:4444/grid/console&lt;/a&gt;&#xA;иҝҷйҮҢйңҖиҰҒжіЁж„Ҹзҡ„жҳҜпјҢеҰӮжһңжҳҜеңЁжң¬ең°иҝҗиЎҢзҡ„е®№еҷЁпјҢе№¶жҳ е°„4444з«ҜеҸЈпјҢеӣ жӯӨеҫ—еҲ°127.0.0.1:4444пјҢеҰӮжһңжҳҜеңЁиҷҡжӢҹжңәдёӯиҝҗиЎҢпјҢipе’Ңз«ҜеҸЈеә”иҜҘж №жҚ®зҪ‘з»ңжқҘиҺ·еҸ–зӣёеә”зҡ„IPе’ҢPORT&lt;/p&gt;</description>
    </item>
    <item>
      <title>wrkжҖ§иғҪжөӢиҜ•е·Ҙе…·дҪҝз”ЁжҖ»з»“</title>
      <link>https://www.yeqown.xyz/2018/01/16/wrk%E6%80%A7%E8%83%BD%E6%B5%8B%E8%AF%95%E5%B7%A5%E5%85%B7%E4%BD%BF%E7%94%A8%E6%80%BB%E7%BB%93/</link>
      <pubDate>Tue, 16 Jan 2018 11:28:59 +0000</pubDate>
      <guid>https://www.yeqown.xyz/2018/01/16/wrk%E6%80%A7%E8%83%BD%E6%B5%8B%E8%AF%95%E5%B7%A5%E5%85%B7%E4%BD%BF%E7%94%A8%E6%80%BB%E7%BB%93/</guid>
      <description>&lt;p&gt;wrk еҺӢеҠӣжөӢиҜ•е·Ҙе…·зҡ„з®ҖеҚ•е°Ҹз»“гҖӮ&#xA;йЎ№зӣ®ең°еқҖпјҡ&lt;a href=&#34;https://github.com/wg/wrk&#34;&gt;https://github.com/wg/wrk&lt;/a&gt;&lt;/p&gt;&#xA;&lt;!-- more --&gt;&#xA;&lt;h3 id=&#34;е®үиЈ…&#34;&gt;е®үиЈ…&lt;a class=&#34;anchor&#34; href=&#34;#%e5%ae%89%e8%a3%85&#34;&gt;#&lt;/a&gt;&lt;/h3&gt;&#xA;&lt;p&gt;Win: &lt;a href=&#34;https://github.com/wg/wrk/wiki/Installing-wrk-on-Windows-10&#34;&gt;https://github.com/wg/wrk/wiki/Installing-wrk-on-Windows-10&lt;/a&gt;&#xA;Linux: &lt;a href=&#34;https://github.com/wg/wrk/wiki/Installing-wrk-on-Linux&#34;&gt;https://github.com/wg/wrk/wiki/Installing-wrk-on-Linux&lt;/a&gt;&#xA;MacOS: &lt;code&gt;brew install wrk&lt;/code&gt;&lt;/p&gt;&#xA;&lt;h3 id=&#34;еҹәжң¬е‘Ҫд»Ө&#34;&gt;еҹәжң¬е‘Ҫд»Ө&lt;a class=&#34;anchor&#34; href=&#34;#%e5%9f%ba%e6%9c%ac%e5%91%bd%e4%bb%a4&#34;&gt;#&lt;/a&gt;&lt;/h3&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;вһң ~ wrk&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;Usage: wrk &amp;lt;options&amp;gt; &amp;lt;url&amp;gt;                            &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  Options:                                            &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    -c, --connections &amp;lt;N&amp;gt;  иҝһжҺҘж•°   &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    -d, --duration    &amp;lt;T&amp;gt;  жҢҒз»ӯж—¶й—ҙ          &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    -t, --threads     &amp;lt;N&amp;gt;  зәҝзЁӢж•°  &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;                                                      &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    -s, --script      &amp;lt;S&amp;gt;  еҲ¶е®ҡluaи„ҡжң¬       &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    -H, --header      &amp;lt;H&amp;gt;  ж·»еҠ иҜ·жұӮеӨҙ     &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;        --latency          жү“еҚ°е»¶иҝҹеҲҶеёғдҝЎжҒҜ&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;        --timeout     &amp;lt;T&amp;gt;  и®ҫзҪ®иҜ·жұӮи¶…ж—¶&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    -v, --version          жү“еҚ°зүҲжң¬дҝЎжҒҜ      &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;                                                      &#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &amp;lt;N&amp;gt;иЎЁзӨәж•°еӯ—еҸӮж•°пјҢж”ҜжҢҒеӣҪйҷ…еҚ•дҪҚ &lt;span style=&#34;color:#f92672&#34;&gt;(&lt;/span&gt;1k, 1M, 1G&lt;span style=&#34;color:#f92672&#34;&gt;)&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &amp;lt;T&amp;gt;иЎЁзӨәж—¶й—ҙеҸӮж•°пјҢж”ҜжҢҒеӣҪйҷ…еҚ•дҪҚ &lt;span style=&#34;color:#f92672&#34;&gt;(&lt;/span&gt;2s, 2m, 2h&lt;span style=&#34;color:#f92672&#34;&gt;)&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h3 id=&#34;з®ҖеҚ•дҪҝз”ЁеҸҠи§ЈйҮҠ&#34;&gt;з®ҖеҚ•дҪҝз”ЁеҸҠи§ЈйҮҠ&lt;a class=&#34;anchor&#34; href=&#34;#%e7%ae%80%e5%8d%95%e4%bd%bf%e7%94%a8%e5%8f%8a%e8%a7%a3%e9%87%8a&#34;&gt;#&lt;/a&gt;&lt;/h3&gt;&#xA;&lt;p&gt;&lt;code&gt;wrk -t1 -d20s -c10 -s post.lua http://api.example.com/fake/post&lt;/code&gt;&#xA;д»ҘеҚ•зәҝзЁӢ дҝқжҢҒ10дёӘиҝһжҺҘ жҢҒз»ӯ20з§’ иҝҗиЎҢpost.luaи„ҡжң¬и®ҝй—®http://api.example.com/fake/post&lt;/p&gt;</description>
    </item>
